VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_ME.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=REPLACE_ME
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_ME.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
VITE_FIREBASE_APP_ID=REPLACE_ME

# Android-only (themes/metro.md §4.2) — real AdMob rewarded ad unit ID for the Play
# Store release build. Leave unset to use Google's public test ad unit ID (always
# serves a real test ad, no AdMob account needed) for local/debug builds.
VITE_ADMOB_REWARDED_AD_UNIT_ID=
