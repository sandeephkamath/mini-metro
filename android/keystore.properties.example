# Copy to android/keystore.properties (gitignored, never committed) and fill in
# real values pointing at your production release keystore.
#
# The keystore itself (release.jks or wherever storeFile points) must also be
# kept outside the repo except for a local, gitignored copy — back it up
# somewhere durable (password manager attachment, secure cloud storage). Losing
# it means the app can never be updated under the same Play Store listing again.
#
# storeFile is resolved relative to the android/ directory (android/app/build.gradle
# reads this file from rootProject, same pattern as local.properties).
storeFile=release.jks
storePassword=
keyAlias=
keyPassword=
