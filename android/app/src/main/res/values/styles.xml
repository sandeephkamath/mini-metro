<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!-- The only theme ever assigned to MainActivity (AndroidManifest.xml) — active
         for the entire app lifetime, not just the initial splash, since nothing
         switches the Activity to AppTheme.NoActionBar afterward. android:windowBackground
         (not the old, invalid "android:background" item — themes/metro.md §11 B24)
         is the real native window background painted before the WebView surface
         (re)attaches, on cold start AND on every resume-from-background alike. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@color/windowBackground</item>
        <item name="windowSplashScreenBackground">@color/windowBackground</item>
    </style>
</resources>